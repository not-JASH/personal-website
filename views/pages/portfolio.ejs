<%- include("../partials/main-index", { page: page }) %>

<main class="app-main-text">
    <section class="app-hero app-hero--compact">
        <h1>Portfolio</h1>
    </section>

    <section class="app-entry-list">
        <% page.items.forEach(function (item) { %>
            <article class="app-portfolio-item" id="<%= item.id %>">
                <div class="app-card-meta">
                    <span><%= item.season %></span>
                    <a href="<%= item.href %>">More Info</a>
                </div>
                <h2><%= item.title %></h2>
                <p><%= item.description %></p>
            </article>
        <% }); %>
    </section>
</main>
