<%- include("../partials/skyrim-nav", { links: page.subnav, compact: false }) %>
<h1 style="padding:25px 0px 25px 0px;">Videos</h1>

<div id="myCarousel" class="carousel slide" data-ride="carousel" data-interval="false">
    <ol class="carousel-indicators">
        <% page.videos.forEach(function (video, index) { %>
            <li data-target="#myCarousel" data-slide-to="<%= index %>" class="<%= index === 0 ? 'active' : '' %>"></li>
        <% }); %>
    </ol>

    <div class="carousel-inner">
        <% page.videos.forEach(function (video, index) { %>
            <div class="item <%= index === 0 ? 'active' : '' %>">
                <div class="app-video-box">
                    <iframe src="<%= video %>" title="Skyrim video <%= index + 1 %>" frameborder="0" allowfullscreen></iframe>
                </div>
            </div>
        <% }); %>
    </div>

    <a class="left carousel-control" href="#myCarousel" data-slide="prev">
        <span class="glyphicon glyphicon-chevron-left"></span>
        <span class="sr-only">Previous</span>
    </a>

    <a class="right carousel-control" href="#myCarousel" data-slide="next">
        <span class="glyphicon glyphicon-chevron-right"></span>
        <span class="sr-only">Next</span>
    </a>
</div>

<p></p>

<hr>
<%- include("../partials/skyrim-nav", { links: page.footerNav, compact: true }) %>
