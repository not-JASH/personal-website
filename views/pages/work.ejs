<%- include("../partials/main-index", { page: page }) %>

<main class="app-main-text">
    <section class="app-hero app-hero--compact">
        <h1>Work Experience</h1>
    </section>

    <section class="app-entry-list">
        <% page.items.forEach(function (entry) { %>
            <article class="app-entry-card">
                <div class="app-card-meta">
                    <span><%= entry.organization %></span>
                    <span><%= entry.dates %></span>
                </div>
                <h2><%= entry.role %></h2>
                <p><%= entry.summary %></p>
            </article>
        <% }); %>
    </section>
</main>
