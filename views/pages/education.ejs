<%- include("../partials/main-index", { page: page }) %>

<main class="app-main-text">
    <section class="app-hero app-hero--compact">
        <p class="app-site-note">Education</p>
        <h1>Education</h1>
        <p class="app-hero__status">Formal study in civil engineering, programming, and the technical foundations behind both.</p>
    </section>

    <section class="app-entry-list">
        <% page.items.forEach(function (entry, index) { %>
            <article class="app-entry-card">
                <div class="app-portfolio-head">
                    <span class="app-item-number"><%= String(index + 1).padStart(2, "0") %></span>
                    <div class="app-card-meta">
                        <span><%= entry.organization %></span>
                        <span><%= entry.dates %></span>
                    </div>
                </div>
                <h2><%= entry.title %></h2>
            </article>
        <% }); %>
    </section>
</main>
