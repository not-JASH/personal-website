<%- include("../partials/skyrim-nav", { links: page.subnav, compact: false }) %>

<div class="app-compare-container">
    <div class="app-compare-box">
        <img src="<%= page.beforeImage %>" alt="Skyrim before image">
        <span>Before</span>
    </div>

    <div class="app-compare-box">
        <img src="<%= page.afterImage %>" alt="Skyrim after image">
        <span>After</span>
    </div>
</div>

<section class="app-media-copy">
    <h1 class="app-page-title">Before &amp; After</h1>
    <h2>Skyrim is truly beautiful, cold, dark, and dangerous.</h2>
    <p><%= page.description %></p>
</section>

<hr>
